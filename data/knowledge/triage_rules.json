[
  {
    "id": "rule_01",
    "title": "Chest pain with shortness of breath",
    "severity": "emergency",
    "triggers_any": ["chest_pain", "shortness_of_breath"],
    "logic": "all",
    "message": "Chest pain together with breathing difficulty can signal a serious heart or lung problem. Seek emergency care immediately.",
    "action": "Go to the emergency department or call emergency services now.",
    "source": {
      "name": "CDC - Emergency warning signs",
      "url": "https://archive.cdc.gov/www_cdc_gov/h1n1flu/warningsigns.htm"
    }
  },
  {
    "id": "rule_02",
    "title": "Persistent chest pain or pressure",
    "severity": "emergency",
    "triggers_any": ["chest_pain"],
    "logic": "all",
    "qualifiers": ["persistent", "pressure", "crushing", "not going away"],
    "message": "Persistent chest pain or pressure needs urgent evaluation.",
    "action": "Seek emergency medical care immediately.",
    "source": {
      "name": "MedlinePlus - Chest Pain",
      "url": "https://medlineplus.gov/chestpain.html"
    }
  },
  {
    "id": "rule_03",
    "title": "Severe or worsening shortness of breath",
    "severity": "emergency",
    "triggers_any": ["shortness_of_breath"],
    "logic": "all",
    "qualifiers": ["severe", "worsening", "cannot catch breath"],
    "message": "Severe breathing difficulty can become dangerous quickly.",
    "action": "Seek emergency medical care immediately.",
    "source": {
      "name": "CDC - Emergency warning signs",
      "url": "https://archive.cdc.gov/www_cdc_gov/h1n1flu/warningsigns.htm"
    }
  },
  {
    "id": "rule_04",
    "title": "Confusion or inability to stay alert",
    "severity": "emergency",
    "triggers_any": ["confusion", "fatigue", "dizziness"],
    "logic": "any",
    "qualifiers": ["confused", "hard to wake", "cannot stay alert", "not interacting"],
    "message": "Confusion or inability to stay alert is an emergency warning sign.",
    "action": "Seek emergency care now.",
    "source": {
      "name": "CDC - Emergency warning signs",
      "url": "https://archive.cdc.gov/www_cdc_gov/h1n1flu/warningsigns.htm"
    }
  },
  {
    "id": "rule_05",
    "title": "Dizziness with chest pain or breathing trouble",
    "severity": "emergency",
    "triggers_any": ["dizziness", "chest_pain", "shortness_of_breath"],
    "logic": "combo",
    "combo_groups": [["dizziness", "chest_pain"], ["dizziness", "shortness_of_breath"]],
    "message": "Dizziness along with chest pain or breathing trouble can indicate a serious condition.",
    "action": "Get urgent emergency evaluation.",
    "source": {
      "name": "CDC - Emergency warning signs",
      "url": "https://archive.cdc.gov/www_cdc_gov/h1n1flu/warningsigns.htm"
    }
  },
  {
    "id": "rule_06",
    "title": "Severe or persistent vomiting",
    "severity": "urgent",
    "triggers_any": ["nausea_vomiting"],
    "logic": "all",
    "qualifiers": ["persistent", "severe", "cannot keep fluids down"],
    "message": "Severe or persistent vomiting increases the risk of dehydration and may point to a more serious problem.",
    "action": "Seek same-day medical care. Go to emergency care if symptoms are severe.",
    "source": {
      "name": "CDC - Emergency warning signs",
      "url": "https://archive.cdc.gov/www_cdc_gov/h1n1flu/warningsigns.htm"
    }
  },
  {
